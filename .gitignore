# Dependencies
node_modules/

# Environment variables — never commit secrets; use .env.example as template
.env
.env.local
.env.*.local

# Build outputs
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# TypeScript incremental build cache
*.tsbuildinfo

# OS artefacts
.DS_Store
Thumbs.db

